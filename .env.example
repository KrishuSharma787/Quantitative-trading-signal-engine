# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# NewsAPI — free key at https://newsapi.org (100 req/day free tier)
NEWS_API_KEY=your_newsapi_key_here

# Gmail SMTP alerts (use an App Password, not your real password)
# Guide: https://support.google.com/accounts/answer/185833
ALERT_EMAIL_FROM=your_gmail@gmail.com
ALERT_EMAIL_TO=your_gmail@gmail.com
ALERT_EMAIL_PASSWORD=your_16_char_app_password
