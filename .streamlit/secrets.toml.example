# .streamlit/secrets.toml
# Used by Streamlit Cloud to inject environment variables
# Copy this structure into the Streamlit Cloud dashboard under "Secrets"
# NEVER commit this file — it's in .gitignore

NEWS_API_KEY          = "your_newsapi_key_here"
ALERT_EMAIL_FROM      = "your_gmail@gmail.com"
ALERT_EMAIL_TO        = "your_gmail@gmail.com"
ALERT_EMAIL_PASSWORD  = "your_16_char_app_password"
